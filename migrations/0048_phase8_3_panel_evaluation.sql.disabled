-- Phase 8.3: 패널 면접 고도화
-- 패널 면접 평가 데이터 저장

-- 패널 면접 개별 평가 테이블
CREATE TABLE IF NOT EXISTS panel_interview_evaluations (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    session_id TEXT NOT NULL,
    interviewer_id TEXT NOT NULL,
    question_index INTEGER NOT NULL,
    answer_text TEXT,
    video_metrics TEXT,  -- JSON
    evaluation_result TEXT,  -- JSON
    score INTEGER,
    feedback TEXT,
    created_at TEXT NOT NULL,
    UNIQUE(session_id, interviewer_id, question_index)
);

-- 패널 면접 종합 리포트 테이블
CREATE TABLE IF NOT EXISTS panel_interview_reports (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    session_id TEXT NOT NULL UNIQUE,
    report_data TEXT NOT NULL,  -- JSON
    final_score INTEGER,
    final_grade TEXT,
    hiring_recommendation TEXT,
    created_at TEXT NOT NULL
);

-- 인덱스
CREATE INDEX IF NOT EXISTS idx_panel_evaluations_session ON panel_interview_evaluations(session_id);
CREATE INDEX IF NOT EXISTS idx_panel_evaluations_interviewer ON panel_interview_evaluations(interviewer_id);
CREATE INDEX IF NOT EXISTS idx_panel_reports_session ON panel_interview_reports(session_id);
CREATE INDEX IF NOT EXISTS idx_panel_reports_score ON panel_interview_reports(final_score DESC);
